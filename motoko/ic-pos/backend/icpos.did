type Response = 
 record {
   data: opt Merchant;
   error_text: opt text;
   status: nat16;
   status_text: text;
 };
type Merchant = 
 record {
   email_address: text;
   email_notifications: bool;
   name: text;
   phone_notifications: bool;
   phone_number: text;
 };
type Main = 
 service {
   getLogs: () -> (vec text) query;
   getMerchant: () -> (Response) query;
   updateMerchant: (merchant: Merchant) -> (Response);
 };
service : (_startBlock: nat) -> Main
